# API (no trailing slash on host; include /api if your server uses that prefix)
VITE_API_BASE=http://localhost:4000/api

# Client routes (must start with /)
VITE_ROUTE_LOGIN=/
VITE_ROUTE_REGISTER=/register
VITE_ROUTE_CHAT=/chat

# After login: path to open (e.g. /chat). Leave empty to remain on login.
VITE_POST_LOGIN_PATH=/chat

# If true, visiting login/register while already logged in redirects to chat.
# Set false during development to avoid auto-opening /chat from old localStorage.
VITE_AUTO_REDIRECT_AUTHENTICATED=false
